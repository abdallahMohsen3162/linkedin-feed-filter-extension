{
  "manifest_version": 3,
  "name": "LinkedIn Reader",
  "version": "1.0.0",
  "description": "Read LinkedIn posts",
  "key": "",
  "permissions": [
    "storage",
    "activeTab",
    "identity"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*"
  ],
  "oauth2": {
    "client_id": "855098238672-lto9l8s7ip46buqm46o2rptqp99a67p7.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/feed/*"
      ],
      "js": [
        "config.js",
        "content.js"
      ]
    }
  ]
}
